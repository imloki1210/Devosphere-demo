{
  "typography": {
    "font_stack_headings": "\"Outfit\", \"Helvetica Neue\", sans-serif",
    "font_stack_body": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
    "font_stack_monospaced": "SFMono-Regular, Menlo, Monaco, Consolas, monospace",
    "default_font_smoothing": "antialiased",
    "computed_properties": {
      "body_text": {
        "font_size": "18px",
        "font_weight": "400",
        "line_height": "25.92px",
        "letter_spacing": "normal",
        "color": "#333333"
      },
      "h1_title": {
        "font_size": "44px",
        "font_weight": "600",
        "line_height": "49.28px",
        "letter_spacing": "-0.02em",
        "color": "#0c0c0c"
      },
      "h2_section": {
        "font_size": "35px",
        "font_weight": "600",
        "line_height": "46.2px",
        "letter_spacing": "-0.01em",
        "color": "#0c0c0c"
      },
      "h3_card": {
        "font_size": "28px",
        "font_weight": "600",
        "line_height": "36.96px",
        "letter_spacing": "-0.01em",
        "color": "#0c0c0c"
      },
      "h4_item": {
        "font_size": "22.5px",
        "font_weight": "700",
        "line_height": "25.2px",
        "letter_spacing": "-0.02em",
        "color": "#0c0c0c"
      }
    }
  },
  "layout_constraints": {
    "max_width_container": "1280px",
    "narrow_container": "960px",
    "wide_container": "1440px",
    "padding_desktop": "0 24px",
    "padding_tablet": "0 16px",
    "padding_mobile": "0 12px"
  },
  "margins_and_paddings": {
    "section_gap_desktop": "96px",
    "section_gap_mobile": "48px",
    "card_padding_inner": "24px",
    "navbar_padding": "16px 24px",
    "button_padding": "7px 16px"
  },
  "grid_layouts": {
    "value_proposition_grid": {
      "columns_desktop": "repeat(3, 1fr)",
      "columns_tablet": "repeat(2, 1fr)",
      "columns_mobile": "1fr",
      "gap": "32px"
    },
    "footer_navigation_grid": {
      "columns_desktop": "repeat(5, 1fr)",
      "columns_tablet": "repeat(2, 1fr)",
      "columns_mobile": "1fr",
      "gap": "40px"
    }
  },
  "flex_layouts": {
    "navbar_flex": {
      "direction": "row",
      "justify": "space-between",
      "align": "center",
      "gap": "16px"
    },
    "button_content_flex": {
      "direction": "row",
      "justify": "center",
      "align": "center",
      "gap": "8px"
    }
  }
}
